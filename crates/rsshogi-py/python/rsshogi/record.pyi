    @property
    def white_time_control(self) -> TimeControl | None: ...
    @property
    def end_time_ms(self) -> int | None: ...
    @property
    def end_comment(self) -> str | None: ...
    def __init__(
        self,
        init_position_sfen: str,
        moves: list[MoveEntry] | None = ...,
        metadata: RecordMetadata | None = ...,
        terminal: SpecialMoveEntry | None = ...,
        initial_comment: str | None = ...,
    ) -> None: ...
    @property
    def move_count(self) -> int: ...
    def update_metadata(
        self,
        patch: RecordMetadata | RecordMetadataDict,
        *,
        strict: bool = ...,
    ) -> None: ...
    def set_metadata_attribute(self, key: str, value: str) -> None: ...
    def remove_metadata_attribute(self, key: str) -> str | None: ...
    def clear_metadata_attributes(self) -> None: ...
    def extend_main_line(self, moves: list[MoveEntry]) -> list[int]: ...
    def set_main_terminal(self, terminal: SpecialMoveEntry) -> int: ...
    def to_kif(self) -> str: ...
    def to_ki2(self) -> str: ...
    def to_csa(self) -> str: ...
    def to_jkf(self) -> str: ...
    def to_usi_position(self, *, include_special_tokens: bool = ...) -> str: ...
    def write_kif(self, path: str | bytes | bytearray, encoding: str | None = ...) -> None: ...
    def write_ki2(self, path: str | bytes | bytearray, encoding: str | None = ...) -> None: ...
    def write_csa(self, path: str | bytes | bytearray, encoding: str | None = ...) -> None: ...
    def write_jkf(self, path: str | bytes | bytearray, encoding: str | None = ...) -> None: ...
    def to_pack(self) -> bytes: ...
    def to_sbinpack(
        self,
        *,
        stem_score: int = ...,
        include_main: bool = ...,
        include_variations: bool = ...,
        metadata: bytes | None = ...,
    ) -> bytes: ...
    def root_node_id(self) -> int: ...
    def main_line_ids(self) -> list[int]: ...
    def node_parent(self, node_id: int) -> int | None: ...
    def node_entry(self, node_id: int) -> RecordEntry | None: ...
    def node_move(self, node_id: int) -> MoveEntry | None: ...
    def node_terminal(self, node_id: int) -> SpecialMoveEntry | None: ...
    def children(self, node_id: int) -> list[int]: ...
    def into_editor(self) -> RecordEditor: ...
    def to_dict(self) -> RecordDict: ...
    def to_psv(self, *, include_main: bool = ..., include_variations: bool = ...) -> list[bytes]: ...
    @classmethod
    def from_kif_str(cls, text: str) -> Record: ...
    @classmethod
    def from_ki2_str(cls, text: str) -> Record: ...
    @classmethod
    def from_csa_str(cls, text: str) -> Record: ...
    @classmethod
    def from_jkf_str(cls, text: str) -> Record: ...
    @classmethod
    def from_usi_position(
        cls,
        position: str,
        *,
        allow_special_tokens: bool = ...,
    ) -> Record: ...
    @classmethod
    def from_kif_file(cls, path: str | bytes | bytearray, encoding: str | None = ...) -> Record: ...
    @classmethod
    def from_ki2_file(cls, path: str | bytes | bytearray, encoding: str | None = ...) -> Record: ...
    @classmethod
    def from_csa_file(cls, path: str | bytes | bytearray, encoding: str | None = ...) -> Record: ...
    @classmethod
    def from_jkf_file(cls, path: str | bytes | bytearray, encoding: str | None = ...) -> Record: ...
    @classmethod
