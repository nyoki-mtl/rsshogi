    def __repr__(self) -> str: ...

class RecordEntry:
    @property
    def kind(self) -> Literal["move", "special"]: ...
    @property
    def move(self) -> MoveEntry | None: ...
    @property
    def special(self) -> SpecialMoveEntry | None: ...
    def __repr__(self) -> str: ...

class GameResultInfo:
