class Record:
    @property
    def init_position_sfen(self) -> str: ...
    initial_comment: str | None
    @property
    def moves(self) -> list[MoveEntry]: ...
    metadata: RecordMetadata
    @property
    def result(self) -> GameResult: ...
    @property
    def result_info(self) -> GameResultInfo: ...
