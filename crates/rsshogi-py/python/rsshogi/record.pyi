    def __repr__(self) -> str: ...

class RecordEditor:
    @property
    def current_node(self) -> int: ...
    @property
    def position(self) -> Board: ...
    @property
    def position_sfen(self) -> str: ...
    def __init__(self, init_position: str) -> None: ...
    @classmethod
    def from_record(cls, record: Record) -> RecordEditor: ...
    def record(self) -> Record: ...
    def into_record(self) -> Record: ...
    def go_to(self, node_id: int) -> None: ...
    def go_back(self) -> bool: ...
    def go_forward(self, child_index: int = ...) -> bool: ...
    def branch_to(self, child_index: int = ...) -> bool: ...
    def append_move(self, move: MoveEntry) -> int: ...
    def append_special(self, special: SpecialMoveEntry) -> int: ...
