# Generated by Cargo
# will have compiled files and executables
debug
target
docs/book/build/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Environment files
.env

# Python virtualenv
.venv

# Python caches
.pytest_cache/
.ruff_cache/
**/__pycache__/
*.pyc

# Python build artifacts
dist/
dist-avx2/
crates/rsshogi-py/python/rsshogi/*.so
crates/rsshogi-py/python/rsshogi/*.pyd

# MkDocs build output
site/

# Kiro tool configuration
.kiro/
# Serena
.serena/

# claude-mem generated CLAUDE.md (keep only root CLAUDE.md)
**/CLAUDE.md
!/CLAUDE.md
.claude/settings.local.json
